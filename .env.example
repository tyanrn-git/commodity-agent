# Скопируйте в .env и заполните значения:
#   cp .env.example .env
#
# Файл .env в gitignore — ключ не попадёт в репозиторий.

# mock — заглушка без реальных запросов (по умолчанию)
# openai — реальный OpenAI (нужен ключ ниже)
AI_PROVIDER=mock

# Ваш ключ с https://platform.openai.com/api-keys
OPENAI_API_KEY=

OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4o

# Tender promotion: legacy | manual | auto_gates
TENDER_PROMOTION_MODE=legacy
AUTO_QUALIFY_SCORE_THRESHOLD=0.65
